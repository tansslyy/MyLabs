<Window x:Class="lab2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab2"
        mc:Ignorable="d"
        Title="TextEditor" Height="450" Width="800">

    <Window.Resources>
        <LinearGradientBrush x:Key="LinearPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="Yellow" Offset="0.0" />
            <GradientStop Color="Cyan" Offset="0.5" />
            <GradientStop Color="Yellow" Offset="1.0" />
        </LinearGradientBrush>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="White" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#FFCBBEBE" BorderThickness="2" CornerRadius="10" Margin="5" 
                Background="{StaticResource LinearPanelBrush}">
            <StackPanel Orientation="Horizontal">
                <Button ToolTip="Відкрити" Width="60" Height="60">
                    <Image Source="images/open.png" />
                </Button>
                <Button ToolTip="Стерти" Width="60" Height="60">
                    <Image Source="images/clear.png" />
                </Button>
                <Button ToolTip="Копіювати" Width="60" Height="60">
                    <Image Source="images/copy.png" />
                </Button>
                <Button ToolTip="Вставити" Width="60" Height="60">
                    <Image Source="images/paste.png" />
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#FFCBBEBE" BorderThickness="2" CornerRadius="10" Margin="5" 
                Background="{StaticResource LinearPanelBrush}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" 
                         VerticalScrollBarVisibility="Visible" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" />

                <DockPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button DockPanel.Dock="Bottom" 
                            Style="{x:Null}"
                            Content="OK" 
                            Width="50" Height="25" 
                            HorizontalAlignment="Center" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>