<Window x:Class="lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="База Клієнтів (Завдання 4)" Height="500" Width="600"
        Loaded="Window_Loaded">

    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Height="35">
                <Button Name="btnCreate" Click="btnCreate_Click" Width="70">Create</Button>
                <Separator />
                <Button Name="btnUpdate" Click="btnUpdate_Click" Width="70">Update</Button>
                <Separator />
                <Button Name="btnDelete" Click="btnDelete_Click" Width="70">Delete</Button>
            </ToolBar>
        </ToolBarTray>

        <Grid DataContext="{Binding ElementName=list, Path=SelectedItem}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" Name="list" 
                     ItemsSource="{Binding}" DisplayMemberPath="Name" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="5">ID:</TextBlock>
            <TextBox x:Name="txtId" Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding Path=Id, Mode=OneWay}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="5">Ім'я:</TextBlock>
            <TextBox x:Name="txtName" Grid.Row="2" Grid.Column="1" Margin="5" Text="{Binding Path=Name, Mode=OneWay}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="5">Телефон:</TextBlock>
            <TextBox x:Name="txtPhone" Grid.Row="3" Grid.Column="1" Margin="5" Text="{Binding Path=Phone, Mode=OneWay}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Margin="5">Адреса:</TextBlock>
            <TextBox x:Name="txtAddress" Grid.Row="4" Grid.Column="1" Margin="5" Text="{Binding Path=Address, Mode=OneWay}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="5">Сума замовлення:</TextBlock>
            <TextBox x:Name="txtOrderAmount" Grid.Row="5" Grid.Column="1" Margin="5" Text="{Binding Path=OrderAmount, Mode=OneWay}" />
        </Grid>
    </DockPanel>
</Window>