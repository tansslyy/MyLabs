<Window x:Class="lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="База Клієнтів" Height="450" Width="600"
        Loaded="Window_Loaded">

    <Grid DataContext="{Binding ElementName=list, Path=SelectedItem}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Name="list" ItemsSource="{Binding}" DisplayMemberPath="Name" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="5">ID:</TextBlock>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding Path=Id, Mode=OneWay}" IsReadOnly="True" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="5">Телефон:</TextBlock>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Text="{Binding Path=Phone, Mode=OneWay}" Focusable="True" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="5">Адреса:</TextBlock>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="5" Text="{Binding Path=Address, Mode=OneWay}" Focusable="True" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="5">Сума замовлення:</TextBlock>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="5" Text="{Binding Path=OrderAmount, Mode=OneWay}" Focusable="True" />
    </Grid>
</Window>